{
  "name": "@ilikosov/yt-sync",
  "version": "0.1.0",
  "description": "Library for syncing YouTube channel videos to a local database",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ilikosov/yt-sync.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "youtube",
    "sync",
    "sqlite",
    "youtube-api"
  ],
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "drizzle-orm": "^0.30.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.5",
    "drizzle-kit": "^0.20.14",
    "typescript": "^5.3.3"
  }
}
